# =============================================================================
#  MVALORACION — .gitignore
# =============================================================================

# ── Entornos virtuales ────────────────────────────────────────────────────────
venv/
env/
.venv/
.env/

# ── Configuración local (contiene rutas y posibles credenciales) ─────────────
config.yaml
config.local.yaml
secrets.yaml
.env
*.local.yaml

# ── Datos financieros (nunca subir al repo) ───────────────────────────────────
data/
outputs/
logs/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.so

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Archivos generados por la app ─────────────────────────────────────────────
# Observaciones: se guardan en data/ (ya excluido)
# Excels exportados
*.xlsx
*.xls
!config.yaml.example

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── Editores ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
*.log.*

# ── Archivos corporativos / temporales ────────────────────────────────────────
chromedriver*
geckodriver*
*.key
*.pem
*.crt
*.pfx
MVALORACION.bat

# ── Legacy (carpeta de archivos históricos — no forman parte del repo) ────────
# legacy/  ← descomenta si quieres excluir la carpeta legacy
