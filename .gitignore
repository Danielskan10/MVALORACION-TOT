# =============================================================================
#  MVALORACION — .gitignore
# =============================================================================

# ── Entornos virtuales ────────────────────────────────────────────────────────
venv/
env/
.venv/
.env/

# ── Configuración local (contiene rutas corporativas) ─────────────────────────
config.yaml
config.local.yaml
secrets.yaml
.env
*.local.yaml

# ── Datos financieros (NUNCA subir al repo) ───────────────────────────────────
data/
outputs/
logs/

# ── Código legado ─────────────────────────────────────────────────────────────
legacy/

# ── Notebooks / docs internos ─────────────────────────────────────────────────
notebooks/
docs/

# ── Scripts de instalación con rutas locales ──────────────────────────────────
setup.ps1
install.ps1

# ── Carpeta de migración antigua (subida por error) ───────────────────────────
MVALORACION-TOT/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.so

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Archivos generados / exportados ───────────────────────────────────────────
*.xlsx
*.xls

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── Editores / agentes ────────────────────────────────────────────────────────
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
*.log.*

# ── Archivos corporativos / temporales ────────────────────────────────────────
chromedriver*
geckodriver*
*.key
*.pem
*.crt
*.pfx
MVALORACION.bat
